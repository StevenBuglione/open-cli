# PostgreSQL database credentials
PG_PASS=changeme-generate-secure-password
PG_USER=authentik
PG_DB=authentik

# Authentik configuration
AUTHENTIK_SECRET_KEY=changeme-generate-long-random-secret
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# Authentik image and tag
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2024.12.0

# Ports (default 9000 for HTTP, 9443 for HTTPS)
AUTHENTIK_PORT_HTTP=9000
AUTHENTIK_PORT_HTTPS=9443

# Runtime token configuration
# These are placeholders for the values you'll configure in the Authentik UI
# AUTHENTIK_ISSUER=http://localhost:9000/application/o/oascli-runtime/
# AUTHENTIK_JWKS_URL=http://localhost:9000/application/o/oascli-runtime/jwks/
# AUTHENTIK_TOKEN_URL=http://localhost:9000/application/o/oascli-runtime/token/
# AUTHENTIK_AUTHORIZATION_URL=http://localhost:9000/application/o/oascli-runtime/authorize/
# AUTHENTIK_BROWSER_CLIENT_ID=oascli-browser

# Runtime configuration
RUNTIME_AUDIENCE=oasclird
RUNTIME_URL=http://localhost:8080
