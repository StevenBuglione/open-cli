{
  "cli": "1.0.0",
  "mode": { "default": "discover" },
  "sources": {
    "tickets": {
      "type": "openapi",
      "uri": "https://example.com/openapi.json",
      "oauth": {
        "mode": "clientCredentials",
        "tokenURL": "https://auth.example.com/oauth/token",
        "clientId": { "type": "env", "value": "CLIENT_ID" },
        "clientSecret": { "type": "env", "value": "CLIENT_SECRET" }
      }
    }
  }
}
